# Copy to .env and adjust as needed.

# PostgreSQL connection (matches docker-compose.yml; host port 5433 -> container 5432)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/events

# JWT settings
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis cache (host port 6380 -> container 6379). Leave blank to disable caching.
REDIS_URL=redis://localhost:6380/0
CACHE_TTL_SECONDS=60
